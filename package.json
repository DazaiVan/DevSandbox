    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "pnpm dev"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.7",
    "@react-three/fiber": "^9.1.2",
    "@types/three": "^0.177.0",
