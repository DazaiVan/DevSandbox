{
  "name": "dev-sandbox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter ./apps/* dev",
    "dev:app": "pnpm --filter ./apps/<your-app-name> dev",
    "build": "pnpm --filter ./apps/* build",
    "build:app": "pnpm --filter ./apps/<your-app-name> build",
    "lint": "eslint .",
    "lint:all": "pnpm -r lint",
