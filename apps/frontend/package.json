{
  "name": "frontend",
  "private": true,
  "scripts": {
    "start:all": "concurrently \"pnpm start:host\" \"pnpm start:app1\" \"pnpm start:app2\"",
    "start:host": "cd packages/host && pnpm dev",
    "start:app1": "cd packages/app1 && pnpm dev",
    "start:app2": "cd packages/app2 && pnpm dev",
    "build": "pnpm -r run build"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.1.12",
    "concurrently": "^9.1.2",
    "typescript": "^4.9.0",
    "vite": "^4.0.0"
  }
}